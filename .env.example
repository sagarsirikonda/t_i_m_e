# Firebase project configuration (from Firebase Console > Project Settings > Your Apps > Web App)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# The Google UID of the researcher/admin account.
# After signing in with Google, find your UID in Firebase Console > Authentication > Users.
# The user with this UID gets the Research tab and can view all participants' data.
VITE_ADMIN_UID=
